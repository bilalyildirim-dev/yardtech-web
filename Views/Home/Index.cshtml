<!-- CONSULTING -->
<section class="section consulting-section">
    <div class="container">
        <div class="section-header" data-aos>
            <div class="section-badge">Stratejik Danışmanlık</div>
            <h2 class="section-title">Teknoloji Stratejinizi <span class="text-gradient">Birlikte</span> Şekillendiriyoruz</h2>
            <p class="section-desc">Sadece yazılım yazmıyoruz — işletmenizin teknoloji yol haritasını çiziyor, ROI'nizi maksimize edecek stratejileri birlikte belirliyoruz.</p>
        </div>
        <div class="consulting-grid">
            <div class="consulting-card" data-aos>
                <div class="consulting-icon">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
                </div>
