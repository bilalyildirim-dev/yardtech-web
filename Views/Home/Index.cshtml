<!-- HERO -->
<section class="hero">
    <div class="hero-bg">
        <div class="grid-pattern"></div>
        <div class="hero-glow"></div>
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
    </div>
    <div class="container">
        <div class="hero-inner">
            <div class="hero-content">
                <div class="badge">
                    <span class="badge-dot"></span>
                    Yapay Zeka • Veri Bilimi • Danışmanlık
                </div>
                <h1 class="hero-title">
                    Geleceğin<br />
                    <span class="text-gradient">Teknolojisini</span><br />
                    İnşa Ediyoruz
                </h1>
                <p class="hero-desc">
                    Yapay zeka çözümleri, ileri veri bilimi ve stratejik teknoloji danışmanlığıyla işletmenizin verilerini rekabet avantajına dönüştürüyoruz. Türkiye'nin en güçlü teknoloji ekibi, sizin yanınızda.
                </p>
                <div class="hero-actions">
                    <a asp-controller="Home" asp-action="Contact" class="btn-primary">
                        Hemen Başla
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                    <a asp-controller="Home" asp-action="About" class="btn-ghost">
                        Daha Fazla Bilgi
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 16 12 12 16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    </a>
                </div>
            </div>
            <div class="hero-visual" data-aos data-aos-delay="150">
                <div class="visual-card">
                    <div class="visual-card-header">
                        <div class="traffic-lights">
                            <span></span><span></span><span></span>
                        </div>
                        <span class="visual-card-title">YardTech AI Dashboard</span>
                        <div class="visual-live-badge">
                            <span class="vlive-dot"></span>LIVE
                        </div>
                    </div>

                    <!-- Area Chart -->
                    <div class="visual-area-wrap">
                        <div class="visual-area-meta">
                            <span class="vam-label">Model Performansı</span>
                            <span class="vam-delta">↑ 34.7%</span>
                        </div>
                        <svg class="area-svg" viewBox="0 0 400 88" preserveAspectRatio="none">
                            <defs>
                                <linearGradient id="aGrad" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#2563EB" stop-opacity="0.22"/>
                                    <stop offset="100%" stop-color="#2563EB" stop-opacity="0.01"/>
                                </linearGradient>
                            </defs>
                            <path fill="url(#aGrad)" d="M0,75 C50,70 80,57 120,46 C160,35 185,40 225,28 C265,16 295,23 335,11 C362,4 380,7 400,3 L400,88 L0,88 Z"/>
                            <path fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M0,75 C50,70 80,57 120,46 C160,35 185,40 225,28 C265,16 295,23 335,11 C362,4 380,7 400,3"/>
                            <circle cx="400" cy="3" r="4.5" fill="#2563EB"/>
                            <circle cx="400" cy="3" r="9" fill="#2563EB" fill-opacity="0.18"/>
                        </svg>
                        <div class="area-labels">
                            <span>Oca</span><span>Mar</span><span>May</span><span>Tem</span><span>Eyl</span><span>Ara</span>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="visual-stats">
                        <div class="vstat">
                            <div class="vstat-value vstat-blue"><span class="counter" data-target="150">0</span>+</div>
                            <div class="vstat-label">AI Modeli</div>
                        </div>
                        <div class="vstat vstat-mid">
                            <div class="vstat-value vstat-teal">50M+</div>
                            <div class="vstat-label">Veri/Gün</div>
                        </div>
                        <div class="vstat">
                            <div class="vstat-value vstat-amber">97%</div>
                            <div class="vstat-label">Doğruluk</div>
                        </div>
                    </div>

                    <!-- Progress Bars -->
                    <div class="visual-progress">
                        <div class="vprog-row">
                            <span class="vprog-label">Model Accuracy</span>
                            <span class="vprog-val">97.3%</span>
                        </div>
                        <div class="vprog-track"><div class="vprog-fill vprog-fill-blue" style="width:97.3%"></div></div>
                        <div class="vprog-row" style="margin-top:.875rem">
                            <span class="vprog-label">Uptime SLA</span>
                            <span class="vprog-val vprog-val-green">99.9%</span>
                        </div>
                        <div class="vprog-track"><div class="vprog-fill vprog-fill-green" style="width:99.9%"></div></div>
                    </div>

                    <!-- Status -->
                    <div class="visual-status">
                        <div class="status-dot pulse"></div>
                        <span>Model aktif — çıkarım yapılıyor</span>
                        <span class="status-time">Şimdi</span>
                    </div>
                </div>

                <div class="visual-float-card float-card-1">
                    <div class="float-card-icon fci-blue">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 8v4l3 3"/></svg>
                    </div>
                    <div>
                        <div class="float-card-label">Model Doğruluğu</div>
                        <div class="float-card-val">97.3% Accuracy</div>
                    </div>
                </div>
                <div class="visual-float-card float-card-2">
                    <div class="float-card-icon fci-cyan">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    </div>
                    <div>
                        <div class="float-card-label">Günlük Veri İşleme</div>
                        <div class="float-card-val">50M+ Kayıt</div>
                    </div>
                </div>
                <div class="visual-float-card float-card-3">
                    <div class="float-card-icon fci-green">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div>
                        <div class="float-card-label">Uptime SLA</div>
                        <div class="float-card-val float-card-val--green">99.9% Garantili</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


