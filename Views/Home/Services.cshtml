@{
    ViewData["Title"] = "Hizmetler";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="hero-bg">
        <div class="grid-pattern"></div>
        <div class="hero-glow"></div>
    </div>
    <div class="container">
        <div class="page-hero-inner" data-aos>
            <div class="section-badge">Hizmetlerimiz</div>
            <h1 class="page-title">Kapsamlı <span class="text-gradient">Teknoloji Çözümleri</span></h1>
            <p class="page-desc">
                Yapay zeka, veri bilimi ve stratejik danışmanlıktan yazılım geliştirmeye kadar işletmenizin tüm teknoloji ihtiyaçlarına özel, uçtan uca çözümler.
            </p>
            <div class="services-hero-pills">
                <span class="services-hero-pill pill-blue">Yapay Zeka & LLM</span>
                <span class="services-hero-pill pill-purple">Veri Bilimi</span>
                <span class="services-hero-pill pill-amber">Danışmanlık</span>
                <span class="services-hero-pill">Yazılım Geliştirme</span>
                <span class="services-hero-pill pill-blue">Bulut & DevOps</span>
                <span class="services-hero-pill pill-red">Siber Güvenlik</span>
            </div>
        </div>
    </div>
</section>

<!-- MAIN SERVICES -->
<section class="section">
