<!-- CTA -->
<section class="cta-section">
    <div class="cta-bg"></div>
    <div class="container">
        <div class="cta-inner" data-aos>
            <div class="section-badge" style="margin:0 auto 1.5rem">Hizmet Alın</div>
            <h2 class="cta-title">Hangi Hizmete İhtiyacınız Var?</h2>
            <p class="cta-desc">Uzman ekibimizle ücretsiz keşif görüşmesi yaparak ihtiyaçlarınıza özel çözümler tasarlayalım.</p>
            <div class="cta-actions">
                <a asp-controller="Home" asp-action="Contact" class="btn-primary btn-lg">
                    Ücretsiz Danışmanlık Al
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>
