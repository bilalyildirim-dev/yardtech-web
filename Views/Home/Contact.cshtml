@model YardTech.Web.Models.ContactViewModel
@{
    ViewData["Title"] = "İletişim";
}

<!-- ═══════════════════════════════════════════════
     PAGE HERO
══════════════════════════════════════════════════ -->
<section class="page-hero page-hero-sm contact-hero">
    <div class="hero-bg">
        <div class="grid-pattern"></div>
        <div class="hero-glow"></div>
    </div>
    <div class="container">
        <div class="page-hero-inner" data-aos>
            <div class="section-badge">Bizimle Konuşun</div>
            <h1 class="page-title">Büyük <span class="text-gradient">Fikirler</span> Buradan Başlar</h1>
            <p class="page-desc">
                Projenizi hayata geçirmek için doğru ekiptesiniz.<br />
                YardTech uzmanları <strong>24 saat içinde</strong> size geri dönmeye hazır.
            </p>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════
     RESPONSE GUARANTEE BAR
══════════════════════════════════════════════════ -->

<!-- ═══════════════════════════════════════════════
     QUICK CONTACT CHANNELS
══════════════════════════════════════════════════ -->
<div class="contact-channels-section">
    <div class="container">
        <div class="contact-channels">

            <a href="mailto:info@yardtech.com" class="contact-channel-card">
                <div class="contact-channel-icon contact-channel-icon--email">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div class="contact-channel-body">
                    <div class="contact-channel-title">E-posta</div>
                    <div class="contact-channel-val">info@yardtech.com</div>
                    <div class="contact-channel-note">Teknik &amp; ticari talepler</div>
                </div>
                <svg class="contact-channel-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="tel:+905389312795" class="contact-channel-card">
                <div class="contact-channel-icon contact-channel-icon--phone">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.13-1.13a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 24 18z"/></svg>
                </div>
                <div class="contact-channel-body">
                    <div class="contact-channel-title">Telefon</div>
                    <div class="contact-channel-val">+90 538 931 27 95</div>
                    <div class="contact-channel-note">Pzt – Cum, 09:00 – 18:00</div>
                </div>
                <svg class="contact-channel-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="#" class="contact-channel-card">
                <div class="contact-channel-icon contact-channel-icon--linkedin">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                </div>
                <div class="contact-channel-body">
                    <div class="contact-channel-title">LinkedIn</div>
                    <div class="contact-channel-val">YardTech Teknoloji</div>
                    <div class="contact-channel-note">Kurumsal ağ &amp; duyurular</div>
                </div>
                <svg class="contact-channel-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     MAIN CONTACT GRID
══════════════════════════════════════════════════ -->
<section class="section contact-main-section">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="success-banner" data-aos>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                @TempData["Success"]
            </div>
        }

        <div class="contact-grid-v2">

            <!-- ── LEFT: Office & Info Panel ── -->
            <div class="contact-info-panel" data-aos>

                <div class="contact-panel-header">
                    <h2>Ofisimize <span class="text-gradient">Bekleriz</span></h2>
                    <p>Yüz yüze görüşmeler için randevu alabilir ya da doğrudan ofisimize uğrayabilirsiniz. Çevrimiçi görüşme için Zoom/Teams bağlantısı da sağlarız.</p>
                </div>

                <!-- Şube Ofis -->
                <div class="contact-office-card">
                    <div class="contact-office-card-header">
                        <div class="contact-office-card-badge">Şube</div>
                        <h4>Diyarbakır – Dicle Teknokent</h4>
                        <p>Sur, Diyarbakır teknoloji üssü</p>
                    </div>
                    <div class="contact-office-card-body">
                        <div class="contact-office-detail">
                            <div class="contact-office-detail-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            </div>
                            <div>
                                <div class="contact-office-detail-label">Adres</div>
                                <div class="contact-office-detail-val">Yiğitçavuş Mah. Silvan Bulvarı Dicle Teknokent No:222/1<br />Sur / Diyarbakır</div>
                            </div>
                        </div>
                        <div class="contact-office-detail">
                            <div class="contact-office-detail-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <div>
                                <div class="contact-office-detail-label">Çalışma Saatleri</div>
                                <div class="contact-office-detail-val">Pazartesi – Cuma<br />09:00 – 18:00</div>
                            </div>
                        </div>
                    </div>
                    <div class="contact-office-map">
                        <a href="https://maps.google.com/?q=Yiğitçavuş+Mah+Silvan+Bulvarı+Dicle+Teknokent+No+222+1+Sur+Diyarbakır" target="_blank" rel="noopener" class="map-open-btn">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Haritada Aç
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                    </div>
                </div>


            </div>

            <!-- ── RIGHT: Premium Form ── -->
            <div class="contact-form-panel" data-aos data-aos-delay="120">
                <div class="contact-form-card-v2">

                    <!-- Card Header -->
                    <div class="contact-form-card-header-v2">
                        <h3>Proje Talebinizi Gönderin</h3>
                    </div>

                    <!-- Card Body -->
                    <div class="contact-form-card-body-v2">
                        <form asp-action="Contact" method="post" novalidate id="contactFormPremium">
                            @Html.AntiForgeryToken()

                            <!-- Name & Email -->
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="FullName">Ad Soyad <span class="form-required">*</span></label>
                                    <input asp-for="FullName" placeholder="Adınız Soyadınız" autocomplete="name" />
                                    <span asp-validation-for="FullName" class="field-error"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Email">E-posta <span class="form-required">*</span></label>
                                    <input asp-for="Email" type="email" placeholder="ornek@sirket.com" autocomplete="email" />
                                    <span asp-validation-for="Email" class="field-error"></span>
                                </div>
                            </div>

                            <!-- Phone & Subject -->
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Phone">Telefon</label>
                                    <input asp-for="Phone" placeholder="+90 (5xx) xxx xx xx" autocomplete="tel" />
                                </div>
                                <div class="form-group">
                                    <label asp-for="Subject">Konu <span class="form-required">*</span></label>
                                    <input asp-for="Subject" id="subjectField" placeholder="Proje Danışmanlığı" />
                                    <span asp-validation-for="Subject" class="field-error"></span>
                                </div>
                            </div>

                            <!-- Message -->
                            <div class="form-group">
                                <label asp-for="Message">Mesajınız <span class="form-required">*</span></label>
                                <textarea asp-for="Message" rows="5" placeholder="Projeniz veya sorunuz hakkında detaylı bilgi verin. Bütçe aralığı, zaman çizelgesi ve beklentilerinizi paylaşırsanız daha hızlı değerlendirme yapabiliriz."></textarea>
                                <span asp-validation-for="Message" class="field-error"></span>
                            </div>

                            <!-- Submit -->
                            <button type="submit" class="btn-primary btn-submit-v2" id="submitBtnPremium">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                                Mesajı Gönder
                            </button>

                            <p class="form-privacy-v2">
                                Bu formu göndererek
                                <a href="#">Gizlilik Politikamızı</a> ve
                                <a href="#">KVKK Aydınlatma Metnimizi</a>
                                kabul etmiş olursunuz.
                            </p>

                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════
     BOTTOM TRUST BAR
══════════════════════════════════════════════════ -->

@section Scripts {
<script>
// ── Service interest chips ──
(function() {
    const chips = document.querySelectorAll('#serviceChips .form-chip');
    const subjectField = document.getElementById('subjectField');
    chips.forEach(chip => {
        chip.addEventListener('click', function() {
            chips.forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            if (subjectField && !subjectField.dataset.userEdited) {
                subjectField.value = this.dataset.val;
            }
        });
    });
    if (subjectField) {
        subjectField.addEventListener('input', function() {
            this.dataset.userEdited = '1';
        });
    }
})();

// ── Submit button state ──
(function() {
    const form = document.getElementById('contactFormPremium');
    const btn  = document.getElementById('submitBtnPremium');
    if (!form || !btn) return;
    form.addEventListener('submit', function() {
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Gönderiliyor...';
        btn.disabled = true;
        setTimeout(() => {
            btn.disabled = false;
            btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Mesajı Gönder';
        }, 3000);
    });
})();
</script>
}
