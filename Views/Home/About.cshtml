@{
    ViewData["Title"] = "Hakkımızda";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="hero-bg">
        <div class="grid-pattern"></div>
        <div class="hero-glow"></div>
    </div>
    <div class="container">
        <div class="page-hero-inner" data-aos>
            <div class="section-badge">Kurumsal Profil</div>
            <h1 class="page-title">YardTech <span class="text-gradient">Hakkında</span></h1>
            <p class="page-desc">
                2020 yılında kurulan YardTech, dijital dünyanın sınırlarını zorlayan mühendislik çözümleri sunmaktadır.
                Geleceğin teknolojilerini bugünden inşa eden bir inovasyon merkezidir.
            </p>
        </div>
    </div>
</section>

<!-- STORY -->
<section class="section">
    <div class="container">
        <div class="about-story-grid">
            <div class="about-story-image" data-aos>
                <div class="story-image-wrap">
                    <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop" alt="YardTech teknoloji" loading="lazy" />
                    <div class="story-image-overlay">
                        <div class="story-image-stat">
                            <div class="stat-num">2020</div>
                            <div class="stat-lbl">Kuruluş Yılı</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="about-story-content" data-aos data-aos-delay="120">
                <div class="section-badge">Hikayemiz</div>
                <h2 class="section-title">Teknoloji ile <span class="text-gradient">Değer</span> Yaratıyoruz</h2>
                <p>
                    YardTech, İstanbul merkezli bir teknoloji şirketi olarak 2020 yılında bir grup tutkulu yazılım mühendisi tarafından kuruldu. Kuruluşumuzdan bu yana, Türkiye'nin önde gelen şirketlerine ve uluslararası müşterilere dünya standartlarında teknoloji çözümleri sunuyoruz.
                </p>
                <p style="margin-bottom:1.75rem">
                    Vizyonumuz; işletmelerin dijital dönüşüm yolculuklarında en güvenilir teknoloji ortağı olmak ve Türkiye'yi teknoloji ihraç eden bir ülke haline getirmektir.
                </p>
                <div class="story-checks">
                    <div class="story-check">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>Yapay zeka, veri bilimi ve yazılım geliştirme uzmanlığı</span>
                    </div>
                    <div class="story-check">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>Kurumsal ve KOBİ müşterilere uçtan uca teknoloji çözümleri</span>
                    </div>
                    <div class="story-check">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>KVKK uyumlu veri işleme ve güvenli altyapı</span>
                    </div>
                    <div class="story-check">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>Bakırköy merkezli, İstanbul genelinde hizmet</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- VALUES -->
<section class="section values-section">
    <div class="container">
        <div class="section-header" data-aos>
            <div class="section-badge">Değerlerimiz</div>
            <h2 class="section-title">Bizi <span class="text-gradient">Biz</span> Yapan İlkeler</h2>
        </div>
        <div class="values-grid">
            <div class="value-card" data-aos data-aos-delay="0">
                <div class="value-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3>Güven & Şeffaflık</h3>
                <p>Her projede tam şeffaflık, dürüst iletişim ve güven temel prensibimizdir.</p>
            </div>
            <div class="value-card" data-aos data-aos-delay="80">
                <div class="value-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                </div>
                <h3>İnovasyon Odaklı</h3>
                <p>Sürekli öğrenme ve yenilikçi yaklaşımla teknolojinin ön saflarında yer alıyoruz.</p>
            </div>
            <div class="value-card" data-aos data-aos-delay="160">
                <div class="value-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3>Ekip Ruhu</h3>
                <p>Müşterilerimizi ve ekip arkadaşlarımızı ailemizin bir parçası olarak görürüz.</p>
            </div>
            <div class="value-card" data-aos data-aos-delay="240">
                <div class="value-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <h3>Mükemmellik</h3>
                <p>Her satır kodda, her tasarım kararında ve her müşteri etkileşiminde mükemmelliği hedefleriz.</p>
            </div>
        </div>
    </div>
</section>


<!-- APPROACH -->
<section class="section approach-section">
    <div class="container">
        <div class="approach-grid">
            <div class="approach-left" data-aos>
                <div class="section-badge">Yaklaşımımız</div>
                <h2 class="section-title">Nasıl <span class="text-gradient">Çalışıyoruz?</span></h2>
                <div class="approach-steps">
                    <div class="approach-step">
                        <div class="approach-step-num">01</div>
                        <div>
                            <h4>Analiz & Keşif</h4>
                            <p>İhtiyaçlarınızı derinlemesine analiz ederek en uygun stratejiyi belirliyoruz.</p>
                        </div>
                    </div>
                    <div class="approach-step">
                        <div class="approach-step-num">02</div>
                        <div>
                            <h4>Çevik Geliştirme</h4>
                            <p>Agile metodolojilerle hızlı prototipleme ve sürekli geri bildirim döngüsü sağlıyoruz.</p>
                        </div>
                    </div>
                    <div class="approach-step">
                        <div class="approach-step-num">03</div>
                        <div>
                            <h4>Uygulama & Destek</h4>
                            <p>Yayına alım sonrası kesintisiz teknik destek ve performans optimizasyonu sunuyoruz.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="approach-right" data-aos data-aos-delay="120">
                <div class="about-stats">
                    <div class="about-stat">
                        <div class="about-stat-num"><span class="counter" data-target="500">0</span>+</div>
                        <div class="about-stat-label">Tamamlanan Proje</div>
                    </div>
                    <div class="about-stat">
                        <div class="about-stat-num"><span class="counter" data-target="50">0</span>+</div>
                        <div class="about-stat-label">Uzman Mühendis</div>
                    </div>
                    <div class="about-stat">
                        <div class="about-stat-num"><span class="counter" data-target="5">0</span>+</div>
                        <div class="about-stat-label">Yıllık Deneyim</div>
                    </div>
                    <div class="about-stat">
                        <div class="about-stat-num"><span class="counter" data-target="10">0</span>+</div>
                        <div class="about-stat-label">Sektörde Aktif</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <div class="cta-bg"></div>
    <div class="container">
        <div class="cta-inner" data-aos>
            <div class="section-badge" style="margin:0 auto 1.5rem">Birlikte Büyüyelim</div>
            <h2 class="cta-title">Dijital Dönüşümünüzü Birlikte Başlatalım</h2>
            <p class="cta-desc">Vizyonunuzu gerçeğe dönüştürmek için ihtiyacınız olan teknolojik partner burada.</p>
            <div class="cta-actions">
                <a asp-controller="Home" asp-action="Contact" class="btn-primary btn-lg">
                    Toplantı Planla
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a asp-controller="Home" asp-action="Services" class="btn-outline btn-lg">Hizmetleri İncele</a>
            </div>
        </div>
    </div>
</section>
