<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="YardTech Teknoloji - Silicon Valley standartlarında yazılım geliştirme, yapay zeka, bulut ve siber güvenlik çözümleri." />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | YardTech" : "YardTech – Geleceğin Teknolojisini İnşa Ediyoruz")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%233B5BBD'/><text y='24' font-size='20' fill='white' font-family='Inter,sans-serif' font-weight='800' x='6'>Y</text></svg>" />
</head>
<body>

    <!-- Navigation -->
    <header class="site-header" id="siteHeader">
        <div class="container">
            <nav class="nav-inner">
                <a asp-controller="Home" asp-action="Index" class="nav-logo">
                    <img src="~/images/logo.jpeg" alt="Yardtech Teknoloji A.Ş." class="site-logo-img" />
                </a>

                <nav class="nav-links" id="navLinks">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Ana Sayfa</a>
                    <a asp-controller="Home" asp-action="About" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">Hakkımızda</a>
                    <a asp-controller="Home" asp-action="Services" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")">Hizmetler</a>
                    <a asp-controller="Home" asp-action="Contact" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">İletişim</a>
                </nav>

                <div class="nav-actions">
                    <a asp-controller="Home" asp-action="Contact" class="btn-primary-sm">
                        Bize Ulaşın
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                    <button class="nav-toggle" id="navToggle" aria-label="Menüyü aç">
                        <span></span><span></span><span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-glow"></div>
        <div class="container">
            <div class="footer-top">
                <div class="footer-brand">
                    <a asp-controller="Home" asp-action="Index" class="nav-logo">
                        <img src="~/images/logo.jpeg" alt="Yardtech Teknoloji A.Ş." class="site-logo-img" />
                    </a>
                    <p class="footer-desc">
                        2020 yılından bu yana, işletmelerin dijital dönüşüm yolculuklarında Silicon Valley standartlarında çözümler sunuyoruz.
                    </p>
                    <div class="footer-social">
                        <a href="#" class="social-link" aria-label="LinkedIn">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                        </a>
                        <a href="#" class="social-link" aria-label="Twitter/X">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                        <a href="#" class="social-link" aria-label="GitHub">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                        </a>
                    </div>
                </div>

                <div class="footer-col">
                    <h4 class="footer-heading">Şirket</h4>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="About">Hakkımızda</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Hizmetlerimiz</a></li>
                        <li><a href="#">Portfolyo</a></li>
                        <li><a href="#">Kariyer</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4 class="footer-heading">Hizmetler</h4>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Services">Yazılım Geliştirme</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Yapay Zeka & Otomasyon</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Bulut Çözümleri</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Siber Güvenlik</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Teknoloji Danışmanlığı</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4 class="footer-heading">İletişim</h4>
                    <ul class="footer-contact-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <a href="mailto:info@yardtech.com">info@yardtech.com</a>
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.13-1.13a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 24 18z"/></svg>
                            <a href="tel:+902125550000">+90 (212) 555 00 00</a>
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            <span>Levent Plaza, No: 42, Beşiktaş, İstanbul</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2024 YardTech Teknoloji A.Ş. Tüm hakları saklıdır.</p>
                <div class="footer-legal">
                    <a href="#">Gizlilik Politikası</a>
                    <a href="#">KVKK Aydınlatma Metni</a>
                    <a href="#">Çerez Politikası</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
